# Copy this file to .env and fill in your values
HF_API_TOKEN=hf_your_token_here
HF_TOKEN=hf_your_token_here
HF_HOME=path/to/huggingface/cache
IMAGE_DATASET=path/to/your/image-stimuli/dataset
RESULTS_DIR=path/to/results/directory

# Optional: dedicated Hugging Face Inference Endpoint for remote key `qwen3-vl-4b`.
# Copy ONE line into `.env` (do not commit `.env`). `run_remote.py` appends `/v1` if missing.
# Example replica URL:
# HF_ENDPOINT_QWEN3_VL_4B_BASE_URL=https://j9cxukk1p8tk8jq9.eu-west-1.aws.endpoints.huggingface.cloud
# If chat completions fail, set the `model` string from the endpoint’s inference cURL:
# HF_ENDPOINT_QWEN3_VL_4B_MODEL=
